local Api = {}

function Api:Check(msg)
    msg = tostring(msg)

    local ascii = {}

    for i = 1, #msg do
        ascii[#ascii + 1] = string.byte(msg:sub(i, i))
    end

    local joined = table.concat(ascii, "")

    local EncodingService = game:GetService("EncodingService")

    local encoded = EncodingService:Base64Encode(buffer.fromstring(joined))

    return buffer.tostring(encoded):gsub("=", "")
end

return Api
