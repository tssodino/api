local Api = {}
-- // Readed the base64 encode from roblox doc

function Api:Check(msg)
    local ascii = {}

    for i = 1, #msg do
        ascii[#ascii + 1] = string.byte(msg, i)
    end

    local joined = table.concat(ascii, "")

    local buffer = buffer.fromstring(joined)
    local encoded = game:GetService("EncodingService"):Base64Encode(buffer)

    return buffer.tostring(encoded):gsub("=", "")
end

return Api
