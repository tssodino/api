local Api = {}
-- // Thanks to the person who helped me

function Api:Check(msg)
    msg = tostring(msg)

    local ascii = {}

    for i = 1, #msg do
        ascii[#ascii + 1] = string.byte(msg:sub(i, i))
    end

    local joined = table.concat(ascii, "")

    local encoded = game:GetService("HttpService"):Base64Encode(joined)

    return encoded:gsub("=", "")
end

return Api
