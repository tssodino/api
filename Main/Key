local Keys = loadstring(game:HttpGet("https://raw.githubusercontent.com/CookieScript/api/refs/heads/main/3/3"))()

local GlobalKeys = {}

for _, v in pairs(Keys) do
    table.insert(GlobalKeys, tostring(EncodeApi:Check(v)))
end

Api.VaildKey = false

for _, v in pairs(GlobalKeys) do
    if v == script_key then
        Api.VaildKey = true
        break
    end
end

return Api.VaildKey
